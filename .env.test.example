# 测试环境 .env — 复制为 /var/www/Yonyou_Red_test/.env

GEMINI_API_KEY=your-gemini-api-key

PORT=3002
BASE_PATH=/Yonyou_red_test
NODE_ENV=production
DEPLOY_ENV=staging

# 测试环境建议改用测试邮箱，避免正式反馈被测试数据干扰
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-qq-mail@qq.com
SMTP_PASS=your-qq-smtp-authorization-code
SMTP_FROM=your-qq-mail@qq.com
STUDY_REFLECTION_MAIL_TO=your-test-mail@example.com
